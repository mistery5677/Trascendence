# --- Data base PostgreSQL ---
POSTGRES_USER=transcendence_admin
POSTGRES_PASSWORD=super_secret_password
POSTGRES_DB=transcendence_db

# A URL que o Prisma (no backend) vai usar para se ligar à base de dados
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@database:5432/${POSTGRES_DB}?schema=public

# --- NestJS port connection ---
BACKEND_PORT=3000

# --- React connection ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
NODE_ENV=development
# NODE_ENV=production