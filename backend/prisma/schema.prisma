generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// Class for the user 
// We use 'model' to e store the information in a table
model user {
    id       Int     @id @default(autoincrement())
    email    String  @unique
    name     String?
    nickname String?
    username String  @unique // Means that we only have one username with that specific name
    password String //Save a encrypted password

    // Avatar profile
    avatarUrl String? // The '?' means optional
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    boardTheme Int @default(1)

    // Porfile statistics
    wins   Int @default(0)
    losses Int @default(0)
    draws  Int @default(0)
    elo    Int @default(800)

    // Player position
    matchesAsPlayerA MatchHistory[] @relation("PlayerAMatches")
    matchesAsPlayerB MatchHistory[] @relation("PlayerBMatches")

    sentRequests     FriendRequest[] @relation("sentRequests")
    receivedRequests FriendRequest[] @relation("receivedRequests")
}

model MatchHistory {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now()) //Stores the date

    // Player A (White pieces)
    playerAId Int
    playerA   user @relation("PlayerAMatches", fields: [playerAId], references: [id])

    // Player B (Black pieces)
    playerBId Int
    playerB   user @relation("PlayerBMatches", fields: [playerBId], references: [id])

    // Result of the match (PLAYER_A_WINS | PLAYER_B_WINS | DRAW)
    result String
}

model FriendRequest {
  id          Int      @id @default(autoincrement())
  senderId    Int
  receiverId  Int
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now()) // Maybe this is not needed

  sender      user     @relation("sentRequests", fields: [senderId], references: [id])
  receiver    user     @relation("receivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId]) // Garants that you only have one friend request from the same person
}

